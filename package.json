{
  "name": "littlecoder",
  "version": "0.1.0",
  "description": "AI Coding Worker with Visual Studio",
  "main": "agent.js",
  "author": "Sourish",
  "homepage": "https://github.com/sourish987/littlecoder",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sourish987/littlecoder.git"
  },
  "bugs": {
    "url": "https://github.com/sourish987/littlecoder/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "setup": "node setup.js",
    "start": "node start.js",
    "demo": "node demo.js",
    "workspace:init": "powershell -ExecutionPolicy Bypass -File ops/manage-workspaces.ps1 init",
    "live:sync": "powershell -ExecutionPolicy Bypass -File ops/manage-workspaces.ps1 sync-live",
    "live:start": "powershell -ExecutionPolicy Bypass -File ops/manage-workspaces.ps1 start-live",
    "release:sync": "powershell -ExecutionPolicy Bypass -File ops/manage-workspaces.ps1 sync-release",
    "release:zip": "powershell -ExecutionPolicy Bypass -File ops/manage-workspaces.ps1 zip-release",
    "engine:start": "node engine/gateway.js start",
    "engine:stop": "node engine/gateway.js stop",
    "engine:status": "node engine/gateway.js status",
    "engine:restart": "node engine/gateway.js restart",
    "worker": "node telegram.js",
    "telegram": "node telegram.js",
    "test": "node -e \"console.log('No tests configured yet')\""
  },
  "keywords": [
    "ai",
    "coding-worker",
    "ollama",
    "local-ai",
    "telegram-bot",
    "developer-tools",
    "studio",
    "agent"
  ],
  "license": "MIT",
  "dependencies": {
    "axios": "^1.16.0",
    "express": "^5.2.1",
    "node-telegram-bot-api": "^0.67.0"
  }
}
